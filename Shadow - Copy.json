      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python Node / CPython3\r\n# Load same-folder script.py\r\n\r\nimport clr\r\nimport os\r\nimport traceback\r\n\r\nSCRIPT_NAME = \"script.py\"\r\n\r\nFALLBACK_SCRIPT_DIR = r\"C:\\Users\\22615\\OneDrive - Gensler\\_REVIT\\Other\\Other_Dynamo\\Dynamo_FunitureDashBoard\"\r\n\r\ndef get_current_dynamo_folder():\r\n    try:\r\n        clr.AddReference(\"DynamoServices\")\r\n        from Dynamo.Applications import DynamoRevit\r\n\r\n        ws = DynamoRevit.RevitDynamoModel.CurrentWorkspace\r\n        dyn_path = ws.FileName\r\n\r\n        if dyn_path and os.path.isfile(dyn_path):\r\n            return os.path.dirname(dyn_path)\r\n    except:\r\n        pass\r\n\r\n    return FALLBACK_SCRIPT_DIR\r\n\r\ntry:\r\n    script_dir = get_current_dynamo_folder()\r\n    script_path = os.path.join(script_dir, SCRIPT_NAME)\r\n\r\n    if not os.path.isfile(script_path):\r\n        raise Exception(\"script.py not found: {}\".format(script_path))\r\n\r\n    with open(script_path, \"r\", encoding=\"utf-8-sig\") as f:\r\n        code = f.read()\r\n\r\n    script_globals = {\r\n        \"__file__\": script_path,\r\n        \"__name__\": \"__dynamo_external_script__\",\r\n        \"IN\": IN,\r\n        \"OUT\": None\r\n    }\r\n\r\n    try:\r\n        script_globals[\"UnwrapElement\"] = UnwrapElement\r\n    except:\r\n        pass\r\n\r\n    exec(compile(code, script_path, \"exec\"), script_globals)\r\n\r\n    script_out = script_globals.get(\"OUT\", None)\r\n\r\n    if script_out is None:\r\n        OUT = {\r\n            \"success\": False,\r\n            \"script_path\": script_path,\r\n            \"error\": \"script.py executed, but OUT is None. Check that script.py contains final OUT assignment.\",\r\n            \"available_keys\": sorted([str(k) for k in script_globals.keys() if not str(k).startswith(\"__\")])\r\n        }\r\n    else:\r\n        OUT = script_out\r\n\r\nexcept Exception:\r\n    OUT = {\r\n        \"success\": False,\r\n        \"script_path\": locals().get(\"script_path\", None),\r\n        \"error\": traceback.format_exc()\r\n    }",
